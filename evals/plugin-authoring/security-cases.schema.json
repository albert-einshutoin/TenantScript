{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tenantscript.dev/schemas/plugin-authoring-security-cases-v1.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "tasks"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "tasks": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": { "$ref": "#/$defs/task" }
    }
  },
  "$defs": {
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["taskId", "cases"],
      "properties": {
        "taskId": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "maxLength": 80 },
        "cases": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "items": { "$ref": "#/$defs/case" }
        }
      }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "hookName", "payload", "capabilityPlan"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "maxLength": 64 },
        "hookName": { "type": "string", "maxLength": 96 },
        "payload": {
          "type": "object",
          "required": ["__proto__", "constructor", "prototype"],
          "maxProperties": 32,
          "additionalProperties": { "$ref": "#/$defs/jsonValue" }
        },
        "capabilityPlan": {
          "type": "array",
          "maxItems": 4,
          "items": { "$ref": "#/$defs/capabilityStep" }
        }
      }
    },
    "capabilityStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "input", "outcome"],
      "properties": {
        "name": { "type": "string", "maxLength": 96 },
        "input": { "$ref": "#/$defs/jsonValue" },
        "outcome": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["status", "value"],
              "properties": {
                "status": { "const": "resolve" },
                "value": { "$ref": "#/$defs/jsonValue" }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["status"],
              "properties": { "status": { "const": "reject" } }
            }
          ]
        }
      }
    },
    "jsonValue": {
      "oneOf": [
        { "type": "null" },
        { "type": "boolean" },
        { "type": "number" },
        { "type": "string", "maxLength": 512 },
        { "type": "array", "maxItems": 32, "items": { "$ref": "#/$defs/jsonValue" } },
        {
          "type": "object",
          "maxProperties": 32,
          "additionalProperties": { "$ref": "#/$defs/jsonValue" }
        }
      ]
    }
  }
}
