      "taskId": "error-provider-failure",
      "cases": [
        {
          "name": "accepts-valid-provider-result",
          "hookName": "incident.opened",
          "payload": { "incidentId": "inc-9", "channel": "incidents" },
          "capabilityPlan": [
            {
              "name": "slack.send",
