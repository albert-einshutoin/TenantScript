    {
      "taskId": "capability-github-issue",
      "cases": [
        {
          "name": "creates-one-issue",
          "hookName": "deployment.failed",
          "payload": { "deploymentId": "dep-123", "reason": "health check failed" },
          "capabilityPlan": [
            {
              "name": "github.issue.create",
              "input": { "title": "Deployment dep-123 failed", "body": "health check failed" },
              "outcome": { "status": "resolve", "value": { "issueId": "issue-1" } }
            }
          ],
          "expected": {
            "result": { "ok": true },
            "capabilityCalls": [
              {
                "name": "github.issue.create",
                "input": { "title": "Deployment dep-123 failed", "body": "health check failed" }
              }
            ]
          }
        },
        {
          "name": "rejects-empty-id",
          "hookName": "deployment.failed",
          "payload": { "deploymentId": "", "reason": "failed" },
          "capabilityPlan": [],
          "expected": {
            "result": {
              "ok": false,
              "error": {
                "name": "PluginHandlerError",
                "hookName": "deployment.failed",
                "message": "invalid_deployment"
              }
            },
            "capabilityCalls": []
          }
        },
        {
          "name": "contains-provider-rejection",
          "hookName": "deployment.failed",
          "payload": { "deploymentId": "dep-123", "reason": "health check failed" },
          "capabilityPlan": [
            {
              "name": "github.issue.create",
              "input": { "title": "Deployment dep-123 failed", "body": "health check failed" },
              "outcome": { "status": "reject" }
            }
          ],
          "expected": {
            "result": {
              "ok": false,
              "error": {
                "name": "PluginHandlerError",
                "hookName": "deployment.failed",
                "message": "issue_creation_failed"
              }
            },
            "capabilityCalls": [
              {
                "name": "github.issue.create",
                "input": { "title": "Deployment dep-123 failed", "body": "health check failed" }
              }
            ]
          }
        },
        {
          "name": "rejects-oversized-reason",
          "hookName": "deployment.failed",
          "payload": {
            "deploymentId": "dep-123",
            "reason": "This deployment failure reason is deliberately longer than the reviewed one hundred and sixty character limit so the candidate must fail closed before calling the provider mutation endpoint at all."
          },
          "capabilityPlan": [],
          "expected": {
            "result": {
              "ok": false,
              "error": {
                "name": "PluginHandlerError",
                "hookName": "deployment.failed",
                "message": "invalid_deployment"
              }
            },
            "capabilityCalls": []
          }
        }
      ]
    },
    {
      "taskId": "capability-slack-alert",
      "cases": [
        {
          "name": "sends-one-alert",
          "hookName": "order.blocked",
          "payload": { "orderId": "ord-42", "reason": "payment review", "channel": "ops-alerts" },
          "capabilityPlan": [
            {
              "name": "slack.send",
              "input": {
                "channel": "ops-alerts",
                "message": "Order ord-42 blocked: payment review"
              },
              "outcome": { "status": "resolve", "value": { "messageId": "msg-1" } }
            }
          ],
          "expected": {
            "result": { "ok": true },
            "capabilityCalls": [
              {
                "name": "slack.send",
                "input": {
                  "channel": "ops-alerts",
                  "message": "Order ord-42 blocked: payment review"
                }
              }
            ]
          }
        },
        {
          "name": "rejects-missing-order",
          "hookName": "order.blocked",
          "payload": { "reason": "payment review", "channel": "ops-alerts" },
          "capabilityPlan": [],
          "expected": {
            "result": {
              "ok": false,
              "error": {
                "name": "PluginHandlerError",
                "hookName": "order.blocked",
                "message": "invalid_blocked_order"
              }
            },
            "capabilityCalls": []
          }
        },
        {
          "name": "rejects-invalid-channel",
          "hookName": "order.blocked",
          "payload": { "orderId": "ord-42", "reason": "payment review", "channel": "" },
          "capabilityPlan": [],
          "expected": {
            "result": {
              "ok": false,
              "error": {
                "name": "PluginHandlerError",
                "hookName": "order.blocked",
                "message": "invalid_blocked_order"
              }
            },
            "capabilityCalls": []
          }
        },
        {
          "name": "contains-provider-rejection",
          "hookName": "order.blocked",
          "payload": { "orderId": "ord-42", "reason": "payment review", "channel": "ops-alerts" },
          "capabilityPlan": [
            {
              "name": "slack.send",
              "input": {
                "channel": "ops-alerts",
                "message": "Order ord-42 blocked: payment review"
              },
              "outcome": { "status": "reject" }
            }
          ],
          "expected": {
            "result": {
              "ok": false,
              "error": {
                "name": "PluginHandlerError",
                "hookName": "order.blocked",
                "message": "alert_failed"
              }
            },
            "capabilityCalls": [
              {
                "name": "slack.send",
                "input": {
                  "channel": "ops-alerts",
                  "message": "Order ord-42 blocked: payment review"
                }
              }
            ]
          }
        }
      ]
    },
