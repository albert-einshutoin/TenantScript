              "outcome": { "status": "resolve", "value": { "messageId": "msg-9" } }
            }
          ],
          "expected": {
            "result": { "ok": true },
            "capabilityCalls": [
              {
                "name": "slack.send",
                "input": { "channel": "incidents", "message": "Incident inc-9 opened" }
              }
            ]
          }
        },
        {
          "name": "contains-provider-rejection",
          "hookName": "incident.opened",
          "payload": { "incidentId": "inc-9", "channel": "incidents" },
          "capabilityPlan": [
            {
              "name": "slack.send",
              "input": { "channel": "incidents", "message": "Incident inc-9 opened" },
              "outcome": { "status": "reject" }
            }
          ],
          "expected": {
            "result": {
              "ok": false,
              "error": {
                "name": "PluginHandlerError",
                "hookName": "incident.opened",
                "message": "notification_failed"
              }
            },
            "capabilityCalls": [
              {
                "name": "slack.send",
                "input": { "channel": "incidents", "message": "Incident inc-9 opened" }
              }
            ]
          }
        },
        {
          "name": "rejects-malformed-provider-result",
          "hookName": "incident.opened",
          "payload": { "incidentId": "inc-9", "channel": "incidents" },
          "capabilityPlan": [
            {
              "name": "slack.send",
              "input": { "channel": "incidents", "message": "Incident inc-9 opened" },
              "outcome": { "status": "resolve", "value": {} }
            }
          ],
          "expected": {
            "result": {
              "ok": false,
              "error": {
                "name": "PluginHandlerError",
                "hookName": "incident.opened",
                "message": "notification_failed"
              }
            },
            "capabilityCalls": [
              {
                "name": "slack.send",
                "input": { "channel": "incidents", "message": "Incident inc-9 opened" }
              }
            ]
          }
        },
        {
          "name": "rejects-invalid-incident",
