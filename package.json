{
  "name": "tenantscript",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "build": "node scripts/publishable-packages.mjs build",
    "changeset": "changeset",
    "changeset:status": "changeset status --since origin/main",
    "changeset:version": "changeset version",
    "pack:check": "node scripts/publishable-packages.mjs check",
    "judge-image:evidence": "node scripts/plugin-authoring-judge-image-evidence.mjs generate .tmp/plugin-authoring-judge-image-evidence",
    "sbom:generate": "node scripts/release-sbom.mjs generate .tmp/release-artifacts/tenantscript.cdx.json",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm lint:adr && pnpm lint:license && pnpm lint:boundaries && pnpm lint:advisory-drills && pnpm lint:incident-drills && pnpm lint:security-reviews && pnpm lint:plugin-reviews && pnpm lint:template-submissions && pnpm lint:template-catalog && pnpm lint:agent-evals && pnpm lint:docs && pnpm -r lint",
    "lint:adr": "node scripts/check-adr-metadata.mjs",
    "lint:license": "node scripts/check-package-license-metadata.mjs",
    "lint:boundaries": "node scripts/check-package-boundaries.mjs",
    "lint:advisory-drills": "node scripts/check-security-advisory-drills.mjs",
    "lint:incident-drills": "node scripts/check-incident-drills.mjs",
    "lint:security-reviews": "node scripts/check-security-review-campaigns.mjs",
    "lint:plugin-reviews": "node scripts/check-plugin-review-records.mjs",
    "lint:template-submissions": "node scripts/check-template-submissions.mjs",
    "lint:template-catalog": "node scripts/generate-template-catalog.mjs",
    "lint:agent-evals": "node scripts/plugin-authoring-eval.mjs",
    "lint:docs": "node scripts/check-doc-command-contracts.mjs && node scripts/check-doc-integrity.mjs",
    "test": "pnpm lint:adr && pnpm lint:license && pnpm lint:boundaries && pnpm lint:advisory-drills && pnpm lint:incident-drills && pnpm lint:security-reviews && pnpm lint:plugin-reviews && pnpm lint:template-submissions && pnpm lint:template-catalog && pnpm lint:agent-evals && pnpm lint:docs && pnpm test:adr && pnpm test:license && pnpm test:boundaries && pnpm test:advisory-drills && pnpm test:incident-drills && pnpm test:security-reviews && pnpm test:plugin-reviews && pnpm test:template-submissions && pnpm test:template-catalog && pnpm test:template-gallery && pnpm test:api-surface && pnpm test:release-policy && pnpm test:release-automation && pnpm test:agent-scaffold && pnpm test:agent-evals && pnpm test:judge-image && pnpm test:admin-ui-accessibility && pnpm test:admin-ui-visual && pnpm test:admin-ui-performance && pnpm test:admin-ui-bundle-budget && pnpm test:packages && pnpm test:sbom && pnpm test:docs && pnpm test:security-program && pnpm test:community-governance && pnpm test:telemetry-contract && pnpm test:chaos-contract && pnpm test:verification && pnpm test:wrangler-template && pnpm -r test",
    "test:adr": "node --test scripts/check-adr-metadata.test.mjs",
    "test:license": "node --test scripts/check-package-license-metadata.test.mjs",
    "test:boundaries": "node --test scripts/check-package-boundaries.test.mjs",
    "test:advisory-drills": "node --test scripts/check-security-advisory-drills.test.mjs",
    "test:incident-drills": "node --test scripts/check-incident-drills.test.mjs",
    "test:security-reviews": "node --test scripts/check-security-review-campaigns.test.mjs",
    "test:plugin-reviews": "node --test scripts/check-plugin-review-records.test.mjs",
    "test:template-submissions": "pnpm build && node --test scripts/check-template-submissions.test.mjs scripts/template-submission-e2e.test.mjs",
    "test:template-catalog": "node --test scripts/generate-template-catalog.test.mjs",
    "test:template-gallery": "pnpm --filter @tenantscript/template-gallery test && pnpm --filter @tenantscript/template-gallery build && pnpm --filter @tenantscript/template-gallery test:e2e",
    "template-catalog:write": "node scripts/generate-template-catalog.mjs --write",
    "test:api-surface": "node --test scripts/public-api-surface.test.mjs && pnpm api-surface:check",
    "test:release-policy": "node --test scripts/release-policy.test.mjs && node scripts/release-policy.mjs && pnpm changeset:status",
    "test:release-automation": "node --test scripts/release-automation.test.mjs",
    "test:packages": "node --test scripts/publishable-packages.test.mjs",
    "test:sbom": "node --test scripts/release-sbom.test.mjs",
    "test:docs": "node --test scripts/agent-onboarding-doc-contract.test.mjs scripts/agent-plugin-authoring-doc-contract.test.mjs scripts/check-doc-command-contracts.test.mjs scripts/check-doc-integrity.test.mjs scripts/cli-reference-doc-contract.test.mjs scripts/configuration-doc-contract.test.mjs scripts/control-plane-error-catalog.test.mjs scripts/docs-landing-page-contract.test.mjs scripts/environment-limitations-doc-contract.test.mjs scripts/glossary-doc-contract.test.mjs scripts/manifest-json-schema-doc-contract.test.mjs scripts/operator-troubleshooting-index.test.mjs scripts/oss-security-entrypoints-doc-contract.test.mjs scripts/phase0-gate-evidence-doc-contract.test.mjs scripts/plugin-review-checklist-doc-contract.test.mjs scripts/readme-public-alpha-contract.test.mjs scripts/rollback-drill-doc-contract.test.mjs scripts/schema-diff-doc-contract.test.mjs scripts/template-submission-doc-contract.test.mjs scripts/test-selection-doc-contract.test.mjs scripts/upgrade-guide-doc-contract.test.mjs",
    "test:agent-scaffold": "pnpm build && node --test scripts/agent-plugin-scaffold-e2e.test.mjs",
    "test:agent-evals": "pnpm --filter @tenantscript/cli... build && node --test scripts/plugin-authoring-eval.test.mjs scripts/plugin-authoring-eval-security.test.mjs scripts/plugin-authoring-isolated-runner.test.mjs scripts/plugin-authoring-isolated-runner-security.test.mjs",
    "test:judge-image": "node --test scripts/plugin-authoring-judge-image.test.mjs scripts/plugin-authoring-judge-image-sbom.test.mjs scripts/plugin-authoring-judge-image.integration.test.mjs",
    "agent-eval:write": "node scripts/plugin-authoring-eval.mjs --write",
    "isolated-agent-eval:run": "node scripts/plugin-authoring-isolated-runner.mjs",
    "test:admin-ui-accessibility": "node --test scripts/admin-ui-accessibility-contract.test.mjs && pnpm --filter @tenantscript/admin-ui test:accessibility",
    "test:admin-ui-visual": "node --test scripts/admin-ui-visual-contract.test.mjs && pnpm --filter @tenantscript/admin-ui test:visual:linux",
    "test:admin-ui-performance": "node --test scripts/admin-ui-performance-contract.test.mjs && pnpm --filter @tenantscript/admin-ui test:performance",
    "test:admin-ui-bundle-budget": "pnpm --filter @tenantscript/admin-ui test:bundle-budget",
    "test:fuzz": "pnpm --filter @tenantscript/manifest test:fuzz && pnpm --filter @tenantscript/host-sdk test:fuzz",
    "test:security-program": "node --test scripts/security-program-contract.test.mjs",
    "test:community-governance": "node --test scripts/community-governance-contract.test.mjs",
    "test:telemetry-contract": "node --test scripts/telemetry-public-contract.test.mjs",
    "test:chaos": "pnpm --filter @tenantscript/loader test:chaos && pnpm --filter @tenantscript/host-sdk test:chaos && pnpm --filter @tenantscript/control-plane test:chaos",
    "test:chaos-contract": "node --test scripts/chaos-nightly-contract.test.mjs",
    "test:verification": "node --test scripts/root-verification-contract.test.mjs",
    "test:wrangler-template": "WRANGLER_SEND_METRICS=false wrangler deploy --dry-run --config deploy/self-host/production/wrangler.example.jsonc --outdir .tmp/wrangler-template",
    "api-surface:check": "node scripts/public-api-surface.mjs",
    "api-surface:write": "node scripts/public-api-surface.mjs --write",
    "control-plane-schema:write": "node scripts/write-control-plane-success-schemas.mjs",
    "release:preflight": "node scripts/release-preflight.mjs",
    "test:coverage": "pnpm -r test:coverage",
    "test:security": "pnpm --filter @tenantscript/cli... build && node --test scripts/plugin-authoring-eval-security.test.mjs scripts/plugin-authoring-isolated-runner-security.test.mjs && pnpm --filter @tenantscript/loader test:security && pnpm --filter @tenantscript/capabilities test:security && pnpm --filter @tenantscript/control-plane test:security && pnpm --filter @tenantscript/proxy test:security && pnpm --filter @tenantscript/admin-ui test:security && pnpm --filter @tenantscript/template-gallery test:security && pnpm --filter @tenantscript/cli test:security",
    "docs:check": "pnpm lint:adr && pnpm lint:docs",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "verify": "pnpm typecheck && pnpm lint && pnpm test && pnpm test:coverage && pnpm test:security && pnpm audit --audit-level high && pnpm format"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@cloudflare/vitest-pool-workers": "^0.18.6",
    "@cloudflare/workers-types": "^5.20260714.1",
    "@cyclonedx/cyclonedx-npm": "^6.0.0",
    "@eslint/js": "^9.29.0",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.8",
    "esbuild": "0.28.1",
    "eslint": "^9.29.0",
    "npm": "11.16.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.0",
    "vitest": "^4.1.8",
    "wrangler": "^4.112.0"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@1.1.15": "1.1.16",
      "brace-expansion@5.0.6": "5.0.7",
      "esbuild@<0.28.1": ">=0.28.1",
      "js-yaml@4.2.0": "4.3.0",
      "sharp@<0.35.0": "0.35.3",
      "undici@>=7.0.0 <7.28.0": "7.28.0",
      "ws@>=8.0.0 <8.21.0": "8.21.0"
    }
  }
}
