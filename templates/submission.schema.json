{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tenantscript.dev/schemas/template-submission-v1.json",
  "title": "TenantScript community template submission",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "slug",
    "displayName",
    "summary",
    "license",
    "source",
    "sdk",
    "hook",
    "capabilities",
    "egress",
    "configKeys",
    "verification",
    "reviewRecord",
    "securityNote",
    "nonGuarantees"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "kind": { "enum": ["community", "simulation"] },
    "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "displayName": { "type": "string", "minLength": 1, "maxLength": 80 },
    "summary": { "type": "string", "minLength": 1, "maxLength": 240 },
    "license": { "type": "string", "minLength": 1, "maxLength": 80 },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "revision", "directory", "files"],
      "properties": {
        "repository": { "type": "string", "format": "uri" },
        "revision": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "directory": { "type": "string", "minLength": 1 },
        "files": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    },
    "sdk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["range", "lastTestedVersion"],
      "properties": {
        "range": { "type": "string", "pattern": "^\\^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "lastTestedVersion": {
          "type": "string",
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
        }
      }
    },
    "hook": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$" },
        "type": { "enum": ["event", "transform", "policy"] }
      }
    },
    "capabilities": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$" }
    },
    "egress": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "allowHosts"],
      "properties": {
        "mode": { "enum": ["deny", "allowlist"] },
        "allowHosts": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[a-z0-9](?:[a-z0-9.-]*[a-z0-9])?$" }
        }
      }
    },
    "configKeys": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9]*$" }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commands", "evidence"],
      "properties": {
        "commands": {
          "type": "object",
          "additionalProperties": false,
          "required": ["build", "test", "audit"],
          "properties": {
            "build": { "const": "pnpm build" },
            "test": { "const": "pnpm test" },
            "audit": {
              "const": "ext audit --manifest ./manifest.json --package ./package.json --bundle ./dist/plugin.cjs"
            }
          }
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "reviewRecord": { "type": "string", "minLength": 1 },
    "securityNote": { "type": "string", "minLength": 1 },
    "nonGuarantees": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 240 }
    }
  }
}
