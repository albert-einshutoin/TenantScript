{
  "name": "@tenantscript/capabilities",
  "version": "0.0.0",
  "description": "Tenant-scoped capability contracts and secure provider adapters for TenantScript plugins.",
  "keywords": [
    "tenantscript",
    "capabilities",
    "saas",
    "plugins",
    "security"
  ],
  "homepage": "https://github.com/albert-einshutoin/TenantScript#readme",
  "bugs": {
    "url": "https://github.com/albert-einshutoin/TenantScript/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/albert-einshutoin/TenantScript.git",
    "directory": "packages/capabilities"
  },
  "type": "module",
  "license": "Apache-2.0",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:security": "vitest run test/security-suite.test.ts test/provider-token-rotation.test.ts test/github-provider.test.ts",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@tenantscript/test-config": "workspace:*"
  }
}
