{
  "name": "@tenantscript/control-plane",
  "version": "0.0.0",
  "type": "module",
  "license": "Apache-2.0",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./rbac": {
      "types": "./dist/rbac.d.ts",
      "import": "./dist/rbac.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run && vitest run --config vitest.workers.config.ts",
    "test:security": "vitest run test/security-suite.test.ts && vitest run --config vitest.workers.config.ts test/security-suite.workers.test.ts test/audit-log.workers.test.ts test/execution-archive.workers.test.ts",
    "test:coverage": "vitest run --coverage && vitest run --config vitest.workers.config.ts"
  },
  "devDependencies": {
    "@tenantscript/test-config": "workspace:*"
  },
  "dependencies": {
    "@tenantscript/host-sdk": "workspace:*",
    "@tenantscript/manifest": "workspace:*"
  }
}
