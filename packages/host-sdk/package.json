{
  "name": "@tenantscript/host-sdk",
  "version": "0.0.0",
  "description": "Typed host integration contracts for TenantScript plugin registration, approval, and hook execution.",
  "keywords": [
    "tenantscript",
    "sdk",
    "saas",
    "plugins",
    "typescript"
  ],
  "homepage": "https://github.com/albert-einshutoin/TenantScript#readme",
  "bugs": {
    "url": "https://github.com/albert-einshutoin/TenantScript/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/albert-einshutoin/TenantScript.git",
    "directory": "packages/host-sdk"
  },
  "type": "module",
  "license": "Apache-2.0",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:chaos": "vitest run test/chaos-suite.test.ts",
    "test:fuzz": "vitest run test/fuzz.test.ts",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@tenantscript/test-config": "workspace:*",
    "@types/semver": "7.7.1",
    "fast-check": "^4.8.0"
  },
  "dependencies": {
    "semver": "7.8.4",
    "zod": "^3.25.76"
  }
}
