{
  "name": "@tenantscript/manifest",
  "version": "0.0.0",
  "description": "Closed schemas and compatibility validation for TenantScript plugin manifests and runtime limits.",
  "keywords": [
    "tenantscript",
    "schema",
    "saas",
    "plugins",
    "validation"
  ],
  "homepage": "https://github.com/albert-einshutoin/TenantScript#readme",
  "bugs": {
    "url": "https://github.com/albert-einshutoin/TenantScript/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/albert-einshutoin/TenantScript.git",
    "directory": "packages/manifest"
  },
  "type": "module",
  "license": "Apache-2.0",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:fuzz": "vitest run test/fuzz.test.ts",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "semver": "7.8.4",
    "zod": "^3.25.64"
  },
  "devDependencies": {
    "@tenantscript/test-config": "workspace:*",
    "@types/semver": "7.7.1",
    "fast-check": "^4.8.0",
    "zod-to-json-schema": "3.25.2"
  }
}
