{
  "name": "@tenantscript/admin-ui",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run && playwright test",
    "test:security": "vitest run src/security-suite.test.tsx",
    "test:coverage": "vitest run --coverage",
    "test:bundle-budget": "node ../../scripts/admin-ui-bundle-budget.test.mjs && vite build && node ../../scripts/admin-ui-bundle-budget.mjs dist bundle-budget.json",
    "test:performance": "playwright test test/e2e/execution-performance.spec.ts",
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@tenantscript/control-plane": "workspace:*",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tenantscript/test-config": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
