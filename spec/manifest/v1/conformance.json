      "expected": "accept",
      "input": {
        "name": "portable-plugin",
        "version": "1.0.0",
        "hooks": [
          {
            "name": "event.received",
            "type": "event",
            "timeoutMs": 100,
            "schemaVersionRange": "^1.0.0",
            "priority": -10
          }
        ],
        "capabilities": {},
        "configSchema": { "properties": {}, "required": [] },
        "egress": { "mode": "deny" },
        "limits": { "cpuMs": 50, "timeoutMs": 500 }
      }
    },
