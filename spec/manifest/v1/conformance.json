{
  "schemaVersion": "1.0.0",
  "manifestSchemaId": "https://raw.githubusercontent.com/albert-einshutoin/TenantScript/main/docs/reference/tenantscript-manifest.schema.json",
  "cases": [
    {
      "id": "accept-allowlist",
      "rule": "egress.allowlist.non-empty",
      "expected": "accept",
      "input": {
        "name": "portable-plugin",
        "version": "1.0.0",
        "hooks": [
          {
            "name": "event.received",
            "type": "event",
            "timeoutMs": 100,
            "schemaVersionRange": "^1.0.0"
          }
        ],
        "capabilities": {},
        "configSchema": { "properties": {}, "required": [] },
        "egress": { "mode": "allowlist", "hosts": ["api.example.com"] },
        "limits": { "cpuMs": 50, "timeoutMs": 500 }
      }
    },
    {
      "id": "accept-capability-config-reference",
      "rule": "capability.key.syntax",
      "expected": "accept",
      "input": {
        "name": "portable-plugin",
        "version": "1.0.0",
        "hooks": [
          {
            "name": "event.received",
            "type": "event",
            "timeoutMs": 100,
            "schemaVersionRange": "^1.0.0"
          }
        ],
        "capabilities": { "message.send": { "channel": "$config.channel" } },
        "configSchema": {
          "properties": { "channel": { "type": "string" } },
          "required": ["channel"]
        },
        "egress": { "mode": "deny" },
        "limits": { "cpuMs": 50, "timeoutMs": 500 }
      }
    },
    {
      "id": "accept-config-default",
      "rule": "config.default.type-match",
      "expected": "accept",
      "input": {
        "name": "portable-plugin",
        "version": "1.0.0",
        "hooks": [
          {
            "name": "event.received",
            "type": "event",
            "timeoutMs": 100,
            "schemaVersionRange": "^1.0.0"
          }
        ],
        "capabilities": {},
        "configSchema": {
          "properties": { "dryRun": { "type": "boolean", "default": false } },
          "required": []
        },
        "egress": { "mode": "deny" },
        "limits": { "cpuMs": 50, "timeoutMs": 500 }
      }
    },
    {
      "id": "accept-minimal-deny",
      "rule": "manifest.valid",
      "expected": "accept",
      "input": {
        "name": "portable-plugin",
